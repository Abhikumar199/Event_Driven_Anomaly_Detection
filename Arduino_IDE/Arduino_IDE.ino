/* -------- ACTIVATION -------- */
float relu(float x){ return (x > 0) ? x : 0; }

/* -------- ANN -------- */
void run_ann(float input[INPUTS], float output[OUTPUTS]){

  float h1[H1];
  float h2[H2];

  for(int j=0;j<H1;j++){
    float sum = BIAS1[j];
    for(int i=0;i<INPUTS;i++)
      sum += input[i] * W1[i][j];
    h1[j] = relu(sum);
  }

  for(int j=0;j<H2;j++){
    float sum = BIAS2[j];
    for(int i=0;i<H1;i++)
      sum += h1[i] * W2[i][j];
    h2[j] = relu(sum);
  }

  for(int j=0;j<OUTPUTS;j++){
    float sum = BIAS3[j];
    for(int i=0;i<H2;i++)
      sum += h2[i] * W3[i][j];
    output[j] = sum;
  }
}

/* -------- SENSOR SIMULATION -------- */
float readTDS(){ return analogRead(35); }
float readTurb(){ return analogRead(34); }
float readFlow(){ return analogRead(32); }

/* -------- SETUP -------- */
void setup(){
  Serial.begin(115200);
}

/* -------- LOOP (MATCHED WITH SNN) -------- */
void loop(){

  float input[3] = {0.5, 0.5, 0.5};
  float out[4];

  for(int i=0;i<1000;i++){
    run_ann(input, out);
  }

  // print output
  Serial.print("Output: ");
  for(int i=0;i<4;i++){
    Serial.print(out[i]);
    Serial.print(" ");
  }
  Serial.println();

  delay(200);
}